# Server
PORT=3001

# Transcription backend: openai | ollama | local
WHISPER_BACKEND=openai

# OpenAI (required if WHISPER_BACKEND=openai or for note generation)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4-turbo-preview

# Toggle note-generation between OpenAI (false) and Ollama (true)
USE_LOCAL_AI=false

# Ollama (required if WHISPER_BACKEND=ollama or USE_LOCAL_AI=true)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# whisper.cpp (required if WHISPER_BACKEND=local)
WHISPER_MODEL_PATH=./models/ggml-large-v3.bin
WHISPER_EXECUTABLE=whisper
